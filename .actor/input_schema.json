{
  "title": "Lead Scraper – Email & WhatsApp",
  "description": "Extrae emails verificados y WhatsApp de negocios por sector, país y ciudad.",
  "type": "object",
  "schemaVersion": 1,
  "properties": {
    "industry": {
      "title": "🏭 Sector",
      "type": "string",
      "description": "Selecciona el sector o industria de los negocios a buscar.",
      "editor": "select",
      "default": "medical_clinics",
      "enum": ["restaurants","hotels","real_estate","construction","law_firms","medical_clinics","dentists","gyms_fitness","beauty_salons","auto_dealerships","accounting_finance","it_technology","marketing_agencies","retail_stores","education_schools","logistics_transport","manufacturing","travel_agencies","insurance","e_commerce"],
      "enumTitles": ["🍽️ Restaurantes","🏨 Hoteles","🏠 Inmobiliaria","🏗️ Construcción","⚖️ Abogados","🏥 Clínicas Médicas","🦷 Dentistas","💪 Gimnasios","💅 Peluquerías y Salones","🚗 Concesionarios","💰 Gestoría y Asesoría","💻 Informática y Tech","📣 Agencias de Marketing","🛒 Tiendas","📚 Academias","🚚 Transportes","🏭 Industria","✈️ Agencias de Viajes","🛡️ Seguros","🛍️ E-Commerce"]
    },
    "country": {
      "title": "🌍 País",
      "type": "string",
      "description": "Selecciona el país objetivo para la búsqueda de leads.",
      "editor": "select",
      "default": "spain",
      "enum": ["spain","mexico","argentina","colombia","chile","peru","united_states","united_kingdom","france","germany","italy","portugal","brazil","uruguay","venezuela","ecuador","bolivia","paraguay","panama","costa_rica"],
      "enumTitles": ["🇪🇸 España","🇲🇽 México","🇦🇷 Argentina","🇨🇴 Colombia","🇨🇱 Chile","🇵🇪 Perú","🇺🇸 Estados Unidos","🇬🇧 Reino Unido","🇫🇷 Francia","🇩🇪 Alemania","🇮🇹 Italia","🇵🇹 Portugal","🇧🇷 Brasil","🇺🇾 Uruguay","🇻🇪 Venezuela","🇪🇨 Ecuador","🇧🇴 Bolivia","🇵🇾 Paraguay","🇵🇦 Panamá","🇨🇷 Costa Rica"]
    },
    "city": {
      "title": "🏙️ Ciudad",
      "type": "string",
      "description": "Ciudad a buscar. Déjalo vacío para buscar en todo el país.",
      "editor": "textfield",
      "default": "",
      "example": "Sevilla"
    },
    "maxResults": {
      "title": "📊 Máximo de resultados",
      "type": "integer",
      "description": "Número máximo de leads a extraer por ejecución.",
      "editor": "number",
      "default": 50,
      "minimum": 1,
      "maximum": 500
    },
    "sources": {
      "title": "🔍 Fuentes",
      "type": "array",
      "description": "Selecciona las fuentes de datos a usar para extraer los leads.",
      "editor": "select",
      "default": ["google_maps", "yellow_pages"],
      "items": {
        "type": "string",
        "enum": ["google_maps", "yellow_pages"],
        "enumTitles": ["🗺️ Google Maps", "📒 PáginasAmarillas"]
      }
    },
    "proxyConfiguration": {
      "title": "🔒 Proxy",
      "type": "object",
      "description": "Configuración de proxy para evitar bloqueos. Se recomienda usar proxies residenciales.",
      "editor": "proxy",
      "default": { "useApifyProxy": true, "apifyProxyGroups": ["RESIDENTIAL"] }
    }
  },
  "required": ["industry", "country"]
}
